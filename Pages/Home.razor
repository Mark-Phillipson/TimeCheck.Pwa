@page "/"
@using TimeCheck.Pwa.Services
@using System.Linq
@inject ISettingsService SettingsService
@inject ITtsService TtsService
@inject ITimeCheckService TimeCheckService
@inject IEncouragementService EncouragementService
@inject IJSRuntime JSRuntime

<PageTitle>Time Check</PageTitle>

<div class="container mt-3">
	<h3>Time Check</h3>

	<div class="mb-3">
		<h1>@_currentTime</h1>
		<button class="btn btn-primary me-2" @onclick="AnnounceTime">Announce Time Now</button>
		<button class="btn btn-secondary" @onclick="SpeakEncouragement">Say Encouragement Now</button>
	</div>

	<div class="mb-3 form-check form-switch">
		<input class="form-check-input" type="checkbox" id="quietSwitch" @bind="SettingsService.IsQuiet" />
		<label class="form-check-label" for="quietSwitch">Quiet mode (pause automatic announcements)</label>
	</div>

	<div class="card mb-3">
		<div class="card-header">Settings</div>
		<div class="card-body">
			<div class="mb-2">
				<label>Time check interval (minutes)</label>
				<input type="number" class="form-control" min="1" @bind="SettingsService.TimeCheckIntervalMinutes" />
			</div>
			<div class="mb-2">
				<label>Encouragement min interval (minutes)</label>
				<input type="number" class="form-control" min="1" @bind="SettingsService.EncouragementIntervalMin" />
			</div>
			<div class="mb-2">
				<label>Encouragement max interval (minutes)</label>
				<input type="number" class="form-control" min="1" @bind="SettingsService.EncouragementIntervalMax" />
			</div>
			<div class="mb-2 form-check">
				<input class="form-check-input" type="checkbox" @bind="SettingsService.EncouragementEnabled" />
				<label class="form-check-label">Enable Encouragement</label>
			</div>

			<div class="mb-2">
				<label>Encouragement messages</label>

				<div class="d-flex gap-2 mb-2">
					<button class="btn btn-success" @onclick="SaveSettings">Save Settings</button>
					<button class="btn btn-warning" @onclick="RequestNotificationPermission">Enable Notifications</button>
					<button class="btn btn-outline-primary ms-auto" @onclick="AddMessage">Add Message</button>
				</div>

				<div class="mb-2">
					<input class="form-control" placeholder="Filter messages..." @bind="_filter" />
				</div>

				<div class="mb-2">
					@foreach (var idx in FilteredIndexes)
					{
						<div class="input-group mb-1">
							<input id="message-@idx" type="text" class="form-control" value="@SettingsService.EncouragementMessages[idx]" @onchange="@(e => UpdateMessage(idx, e?.Value?.ToString()))" />
							<button class="btn btn-outline-danger" @onclick="(() => RemoveMessage(idx))">Remove</button>
						</div>
					}
				</div>
			</div>
		</div>
	</div>
</div>

@code {
	private string _currentTime = DateTime.Now.ToString("h:mm tt");
	private System.Timers.Timer? _clockTimer;
	private string _filter = string.Empty;

	private IEnumerable<int> FilteredIndexes =>
		SettingsService.EncouragementMessages
			.Select((m, idx) => new { m, idx })
			.Where(x => string.IsNullOrWhiteSpace(_filter) || x.m.Contains(_filter, StringComparison.OrdinalIgnoreCase))
			.Select(x => x.idx);

	protected override async Task OnInitializedAsync()
	{
		await SettingsService.LoadAsync();
		await TimeCheckService.StartAsync();
		await EncouragementService.StartAsync();

		_clockTimer = new System.Timers.Timer(1000);
		_clockTimer.Elapsed += (s, e) =>
		{
			_currentTime = DateTime.Now.ToString("h:mm tt");
			InvokeAsync(StateHasChanged);
		};
		_clockTimer.Start();
	}

	private async Task AnnounceTime()
	{
		await TimeCheckService.SayTimeNowAsync();
	}

	private async Task SpeakEncouragement()
	{
		await EncouragementService.SayEncouragementNowAsync();
	}

	private async Task SaveSettings()
	{
		await SettingsService.SaveAsync();
	}

	private async Task AddMessage()
	{
		SettingsService.EncouragementMessages.Add("New encouragement message");
		var idx = SettingsService.EncouragementMessages.Count - 1;
		// Clear filter so the new message is visible, then let Blazor render the new input;
		// yield so the browser updates the DOM, then focus and select the new input via JS interop.
		_filter = string.Empty;
		await InvokeAsync(StateHasChanged);
		await Task.Yield();
		try
		{
			await JSRuntime.InvokeVoidAsync("timecheck.focusElementById", $"message-{idx}");
		}
		catch { }
	}

	private void RemoveMessage(int index)
	{
		if (index >= 0 && index < SettingsService.EncouragementMessages.Count)
			SettingsService.EncouragementMessages.RemoveAt(index);
	}

	private void UpdateMessage(int index, string? value)
	{
		if (value is null)
			return;

		if (index >= 0 && index < SettingsService.EncouragementMessages.Count)
		{
			SettingsService.EncouragementMessages[index] = value;
		}
		else if (index == SettingsService.EncouragementMessages.Count)
		{
			// in case UI attempted to update the next slot, append safely
			SettingsService.EncouragementMessages.Add(value);
		}
	}

	private async Task RequestNotificationPermission()
	{
		try
		{
			var result = await JSRuntime.InvokeAsync<string>("timecheck.requestNotificationPermission");
			if (result == "granted")
			{
				await JSRuntime.InvokeVoidAsync("timecheck.showNotification", "TimeCheck", "Notifications enabled.");
			}
		}
		catch { }
	}

	public async ValueTask DisposeAsync()
	{
		if (_clockTimer != null)
		{
			_clockTimer.Stop();
			_clockTimer.Dispose();
		}
		await TimeCheckService.StopAsync();
		await EncouragementService.StopAsync();
	}
}
