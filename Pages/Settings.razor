@page "/Settings"
@using TimeCheck.Pwa.Services
@inject ISettingsService SettingsService
@inject IJSRuntime JSRuntime

<PageTitle>Settings</PageTitle>

<div class="container mt-3">
    <h3>Settings</h3>

    <div class="mb-3 form-check form-switch">
        <input class="form-check-input" type="checkbox" id="quietSwitch" @bind="SettingsService.IsQuiet" />
        <label class="form-check-label" for="quietSwitch">Quiet mode (pause automatic announcements)</label>
    </div>

    <div class="card mb-3">
        <div class="card-header">Settings</div>
        <div class="card-body">
            <div class="mb-2">
                <label>Time check interval (minutes)</label>
                <input type="number" class="form-control" min="1" @bind="SettingsService.TimeCheckIntervalMinutes" />
            </div>
            <div class="mb-2">
                <label>Encouragement min interval (minutes)</label>
                <input type="number" class="form-control" min="1" @bind="SettingsService.EncouragementIntervalMin" />
            </div>
            <div class="mb-2">
                <label>Encouragement max interval (minutes)</label>
                <input type="number" class="form-control" min="1" @bind="SettingsService.EncouragementIntervalMax" />
            </div>
            <!-- Feature toggles moved to Home screen for quick access -->

            <div class="d-flex gap-2 mb-2">
                <button class="btn btn-success" @onclick="SaveSettings">Save Settings</button>
                <button class="btn btn-outline-secondary" @onclick="TestVoice">Test Voice</button>
            </div>

            <div class="mb-2">
                <label>Voice</label>
                <select class="form-select" @bind="SettingsService.Voice">
                    <option value="">(Default)</option>
                    @foreach (var v in Voices)
                    {
                        <option value="@v.VoiceURI">@v.Name (@v.Lang)</option>
                    }
                </select>
            </div>

            <div class="d-flex gap-2 mb-2">
                <button class="btn btn-warning" @onclick="RequestNotificationPermission">Enable Notifications</button>
                <button class="btn btn-primary" onclick="timecheck.playSampleAudio(true)">Play Sample Audio</button>
                <button class="btn btn-secondary" onclick="timecheck.stopSampleAudio()">Stop Sample Audio</button>
            </div>
        </div>
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await SettingsService.LoadAsync();
        try
        {
            var list = await JSRuntime.InvokeAsync<VoiceInfo[]>("timecheck.getVoices");
            if (list != null) Voices = list.ToList();
        }
        catch { }
    }

    private async Task SaveSettings()
    {
        await SettingsService.SaveAsync();
    }

    private async Task RequestNotificationPermission()
    {
        try
        {
            var result = await JSRuntime.InvokeAsync<string>("timecheck.requestNotificationPermission");
            if (result == "granted")
            {
                await JSRuntime.InvokeVoidAsync("timecheck.showNotification", "TimeCheck", "Notifications enabled.");
            }
        }
        catch { }
    }

    private async Task PlaySampleAudio()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("timecheck.playSampleAudio", true);
        }
        catch { }
    }

    private async Task StopSampleAudio()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("timecheck.stopSampleAudio");
        }
        catch { }
    }

    private async Task TestVoice()
    {
        try
        {
            var sample = "This is a test of the selected voice.";
            var voiceId = SettingsService.Voice;
            await JSRuntime.InvokeVoidAsync("timecheck.speak", sample, true, voiceId);
        }
        catch { }
    }

    private List<VoiceInfo> Voices { get; set; } = new List<VoiceInfo>();

    private class VoiceInfo
    {
        public string Name { get; set; } = string.Empty;
        public string Lang { get; set; } = string.Empty;
        public string VoiceURI { get; set; } = string.Empty;
    }
}
