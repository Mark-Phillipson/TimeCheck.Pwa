@inherits LayoutComponentBase
@using TimeCheck.Pwa.Services
@inject ISettingsService SettingsService
@inject ITimeCheckService TimeCheckService
@inject IEncouragementService EncouragementService
@inject IJokeService JokeService
<div class="page">
    <TopNav />
    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>

    <BottomNav />
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await SettingsService.LoadAsync();
        if (SettingsService.TimeCheckEnabled)
        {
            await TimeCheckService.StartAsync();
        }

        if (SettingsService.EncouragementEnabled)
        {
            await EncouragementService.StartAsync();
        }

        if (SettingsService.JokesEnabled)
        {
            await JokeService.StartAsync();
        }
    }
}
