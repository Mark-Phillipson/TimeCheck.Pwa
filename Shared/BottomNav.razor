@using System
@inject NavigationManager NavManager

@* Mobile bottom navigation for app-like chrome *@
<nav class="bottom-nav safe-area-bottom" role="navigation" aria-label="Primary navigation">
    <button class="nav-item @(IsActive(""))" type="button" @onclick="GoHome" aria-label="Home">
        <svg class="icon" viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true">
            <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" />
        </svg>
        <span class="label">Home</span>
    </button>
    <button class="nav-item @(IsActive("Settings"))" type="button" @onclick="GoSettings">
        <span class="icon" aria-hidden="true">⚙️</span>
        <span class="label">Settings</span>
    </button>
    <button class="nav-item @(IsActive("Jokes"))" type="button" @onclick="GoJokes">
        <span class="icon" aria-hidden="true">😂</span>
        <span class="label">Jokes</span>
    </button>
    <button class="nav-item @(IsActive("Encouragements"))" type="button" @onclick="GoMessages">
        <span class="icon" aria-hidden="true">💬</span>
        <span class="label">Messages</span>
    </button>
</nav>

@code {
    private string IsActive(string relative)
    {
        var current = NavManager.ToBaseRelativePath(NavManager.Uri).Trim('/');
        var target = (relative ?? "").Trim('/');
        if (string.IsNullOrEmpty(target))
            return string.IsNullOrEmpty(current) ? "active" : string.Empty;
        return string.Equals(current, target, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;
    }

    private void GoHome() => NavManager.NavigateTo("/");
    private void GoSettings() => NavManager.NavigateTo("/Settings");
    private void GoJokes() => NavManager.NavigateTo("/Jokes");
    private void GoMessages() => NavManager.NavigateTo("/Encouragements");
}
